<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="assistantDialog"
        title="Assistente de Logística"
        contentWidth="420px"
        contentHeight="500px"
        draggable="true"
        resizable="true"
        verticalScrolling="false"
        icon="sap-icon://da-2">

        <customHeader>
            <Bar>
                <contentLeft>
                    <core:Icon src="sap-icon://da-2" class="sapUiSmallMarginEnd"/>
                    <Title text="Assistente de Logística"/>
                </contentLeft>
                <contentRight>
                    <Button icon="sap-icon://decline" press=".onCloseAssistant" type="Transparent"/>
                </contentRight>
            </Bar>
        </customHeader>

        <VBox class="sapUiNoContentPadding" height="100%" renderType="Bare">
            <!-- Chat History -->
            <ScrollContainer id="chatScroll" vertical="true" class="sapUiTinyMargin" width="100%">
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0" />
                </layoutData>
                <VBox id="chatMessages" class="sapUiSmallMargin">
                    <MessageStrip
                        text="Olá! Sou seu assistente de logística. Diga o que precisa registrar ou use o microfone."
                        type="Information"
                        showIcon="true"
                        showCloseButton="false"
                        class="sapUiSmallMarginBottom"/>
                </VBox>
            </ScrollContainer>

            <!-- Input Area -->
            <Toolbar class="sapUiTinyMarginTop">
                <layoutData>
                    <FlexItemData shrinkFactor="0" />
                </layoutData>
                <Input id="chatInput"
                    placeholder="Digite sua mensagem..."
                    width="100%"
                    submit=".onSendMessage"
                    class="sapUiSmallMarginEnd"/>
                <Button id="micButton"
                    icon="sap-icon://microphone"
                    type="Emphasized"
                    press=".onMicPress"
                    tooltip="Falar"/>
                <Button
                    icon="sap-icon://paper-plane"
                    type="Emphasized"
                    press=".onSendMessage"
                    tooltip="Enviar"/>
            </Toolbar>
        </VBox>

        <beginButton>
            <Button text="Limpar Conversa" icon="sap-icon://delete" press=".onClearChat" type="Transparent"/>
        </beginButton>

    </Dialog>

</core:FragmentDefinition>
